                                    </div>

                                    <!-- Blog Content -->
                                    <div class="card-body p-4 d-flex flex-column">

                                        <div class="d-flex justify-content-between align-items-start mb-2">

                                            <h5 class="card-title fw-bold text-dark mb-0"
                                                style="font-family: 'Outfit', sans-serif;">
                                                <a href="/blog/<%= blog.slug %>"
                                                    style="text-decoration:none; color:inherit;">
                                                    <%= blog.title %>
                                                </a>
                                            </h5>

                                            <% if (blog.category) { %>
                                                <span class="badge text-bg-primary rounded-pill small px-2">
                                                    <%= blog.category %>
                                                </span>
                                                <% } %>

                                        </div>

                                        <!-- Date -->
                                        <p class="text-muted small mb-2">
                                            <%= new Date(blog.createdAt).toDateString() %>
                                        </p>

                                        <!-- Description -->
                                        <p class="card-text text-secondary small mb-4 lh-base">
                                            <%= blog.metaDescription ? blog.metaDescription.substring(0, 110) + '...' :
                                                blog.content.replace(/<[^>]*>/g, '').substring(0, 110) + '...'
                                                %>
                                        </p>

                                        <!-- Button -->
                                        <div class="mt-auto text-center">
                                            <a href="/blog/<%= blog.slug %>"
                                                class="btn btn-primary btn-sm px-3 rounded-pill fw-medium"
                                                style="background: #3498db; border-color: #3498db;">
                                                Read Blog →
                                            </a>
                                        </div>

                                    </div>


                                </div>

                            </div>

                            <% }); %>

                                <% } %>
                                    <div class="text-center mt-4">
                                        <a href="/blog"
                                            class="btn btn-outline-primary px-4 py-2 rounded-pill fw-medium">
                                            More Blogs →
                                        </a>
                                    </div>
            </div>

        </div>

        <div class="mt-5 pt-3 pb-0"></div>

    <!-- Inline footer styles (self-contained to avoid conflicts) -->
    <style>
        .aks-footer {
            background: #08080f;
            color: #cbd5e1;
            font-family: 'Inter', sans-serif;
            position: relative;
            overflow: hidden;
        }

        /* Subtle gradient glow bg */
        .aks-footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 700px;
            height: 350px;
            background: radial-gradient(ellipse at center, rgba(79, 70, 229, 0.08) 0%, transparent 70%);
            pointer-events: none;
        }

        .footer-gradient-line {
            height: 2px;
            background: linear-gradient(90deg, transparent, #4f46e5, #7c3aed, #0ea5e9, transparent);
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 56px 24px 32px;
            position: relative;
            z-index: 1;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
            gap: 40px;
        }

        /* Brand Column */
        .footer-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            margin-bottom: 14px;
        }

        .footer-logo img {
            border-radius: 8px;
        }

        .footer-logo-text {
            font-family: 'Outfit', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: #f1f1f1;
            letter-spacing: -0.3px;
        }

        .footer-accent {
            color: #818cf8;
        }

        .footer-tagline {
            font-size: 13.5px;
            line-height: 1.65;
            color: #6b7280;
            margin-bottom: 20px;
        }

        /* CTA Buttons */
        .footer-cta-group {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .footer-cta {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 16px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            border: 1px solid transparent;
            transition: all 0.2s ease;
        }

        .footer-cta-phone {
            background: rgba(79, 70, 229, 0.12);
            border-color: rgba(79, 70, 229, 0.25);
            color: #a5b4fc;
        }

        .footer-cta-whatsapp {
            background: rgba(34, 197, 94, 0.1);
            border-color: rgba(34, 197, 94, 0.25);
            color: #4ade80;
        }

        .footer-cta-contact {
            background: rgba(14, 165, 233, 0.1);
            border-color: rgba(14, 165, 233, 0.25);
            color: #38bdf8;
        }

        .footer-cta:hover {
            transform: translateY(-2px);
            filter: brightness(1.15);
        }

        /* Column headings */
        .footer-col-heading {
            font-size: 11px;
            font-weight: 700;
            color: #6366f1;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 16px;
            position: relative;
            padding-bottom: 10px;
        }

        .footer-col-heading::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 28px;
            height: 2px;
            background: linear-gradient(90deg, #4f46e5, #7c3aed);
            border-radius: 2px;
        }

        /* Link lists */
        .footer-links {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 9px;
        }

        .footer-links a {
            display: flex;
            align-items: center;
            gap: 7px;
            color: #6b7280;
            text-decoration: none;
            font-size: 13.5px;
            transition: color 0.2s, gap 0.2s;
        }

        .footer-links a:hover {
            color: #a5b4fc;
            gap: 10px;
        }

        .footer-links i {
            font-size: 9px;
            color: #4f46e5;
            flex-shrink: 0;
            transition: color 0.2s;
        }

        .footer-links a:hover i {
            color: #818cf8;
        }

        /* Latest posts */
        .footer-posts {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .footer-post-link {
            display: flex;
            align-items: flex-start;
            gap: 9px;
            color: #6b7280;
            text-decoration: none;
            font-size: 13px;
            line-height: 1.45;
            transition: color 0.2s;
        }

        .footer-post-link:hover {
            color: #a5b4fc;
        }

        .footer-post-icon {
            width: 26px;
            height: 26px;
            background: rgba(79, 70, 229, 0.1);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 11px;
            color: #818cf8;
            transition: background 0.2s;
        }

        .footer-post-link:hover .footer-post-icon {
            background: rgba(79, 70, 229, 0.2);
        }

        /* Divider */
        .footer-divider {
            border: none;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            margin: 40px 0 28px;
        }

        /* Bottom row */
        .footer-bottom {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        /* Social icons */
        .footer-social {
            display: flex;
            gap: 8px;
        }

        .footer-social-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.07);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6b7280;
            font-size: 14px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .footer-social-icon:hover {
            background: rgba(79, 70, 229, 0.15);
            border-color: rgba(79, 70, 229, 0.3);
            color: #a5b4fc;
            transform: translateY(-2px);
        }

        .footer-copyright {
            font-size: 13px;
            color: #4b5563;
            margin: 0;
        }

        .footer-legal {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
        }

        .footer-legal a {
            color: #4b5563;
            text-decoration: none;
            transition: color 0.2s;
        }

        .footer-legal a:hover {
            color: #818cf8;
        }

        .footer-dot {
            color: #374151;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .footer-grid {
                grid-template-columns: 1fr 1fr;
            }

            .footer-brand-col {
                grid-column: 1 / -1;
            }
        }

        @media (max-width: 640px) {
            .footer-grid {
                grid-template-columns: 1fr;
            }

            .footer-bottom {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            .footer-container {
                padding: 40px 20px 24px;
            }
        }
    </style>

    <!-- Scripts (deferred) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" defer></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js" defer></script>
    <script src="/script.js" defer></script>

    <script>
        // Dynamic copyright year
        document.getElementById('footerYear').textContent = new Date().getFullYear();
    </script>
</footer>


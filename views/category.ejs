<%- include('partials/header') %>

    <main class="aks-blog-container">

        <div class="aks-page-header">
            <h1><span class="highlight">
                    <%= categoryName %>
                </span> for the Future</h1>
            <p>Explore our latest insights, tutorials, and articles on <%= categoryName %>.</p>
        </div>

        <% if (blogs.length> 0) { %>

            <!-- ================= HERO SECTION ================= -->
            <% const heroBlog=blogs[0]; %>
                <section class="aks-blog-hero">
                    <a href="/blog/<%= heroBlog.slug %>" class="hero-card">
                        <div class="hero-image-wrapper">
                            <img src="<%= heroBlog.image ? '/uploads/' + heroBlog.image : '/images/placeholder.jpg' %>"
                                alt="<%= heroBlog.title %>" class="hero-image" loading="lazy">
                            <div class="hero-overlay"></div>
                            <% if (heroBlog.category) { %>
                                <span class="category-badge">
                                    <%= heroBlog.category %>
                                </span>
                                <% } %>
                        </div>
                        <div class="hero-content">
                            <% const wordCount=heroBlog.content.replace(/<[^>]+>/g,
                                '').split(/\s+/).filter(Boolean).length;
                                const readTime = Math.max(1, Math.ceil(wordCount / 200));
                                %>
                                <div class="meta-data">
                                    <span class="author"><i class="fa-solid fa-user-circle"></i> Ankit Singh</span>
                                    <span class="read-time"><i class="fa-solid fa-clock"></i>
                                        <%= readTime %> min read
                                    </span>
                                    <span class="date"><i class="fa-solid fa-calendar-alt"></i>
                                        <%= new Date(heroBlog.createdAt).toLocaleDateString('en-US', { month: 'short' ,
                                            day: 'numeric' , year: 'numeric' }) %>
                                    </span>
                                </div>
                                <h2>
                                    <%= heroBlog.title %>
                                </h2>
                                <p class="hero-excerpt">
                                    <%- heroBlog.metaDescription ? heroBlog.metaDescription.substring(0, 150) :
                                        heroBlog.content.replace(/<[^>]*>/g, '').substring(0, 150) %>...
                                </p>
                                <span class="btn-read-more">Read Article <i class="fa-solid fa-arrow-right"></i></span>
                        </div>
                    </a>
                </section>

                <!-- ================= BLOG GRID ================= -->
                <section class="aks-blog-grid">
                    <% blogs.slice(1).forEach(blog=> {
                        const bcWordCount = blog.content.replace(/<[^>]+>/g, '').split(/\s+/).filter(Boolean).length;
                            const bcReadTime = Math.max(1, Math.ceil(bcWordCount / 200));
                            %>
                            <a href="/blog/<%= blog.slug %>" class="blog-card">
                                <div class="card-image-wrapper">
                                    <img src="<%= blog.image ? '/uploads/' + blog.image : '/images/placeholder.jpg' %>"
                                        alt="<%= blog.title %>" loading="lazy">
                                    <% if (blog.category) { %>
                                        <span class="card-badge">
                                            <%= blog.category %>
                                        </span>
                                        <% } %>
                                </div>
                                <div class="card-content">
                                    <div class="card-meta">
                                        <span><i class="fa-solid fa-clock"></i>
                                            <%= bcReadTime %> min
                                        </span>
                                        <span><i class="fa-solid fa-calendar-alt"></i>
                                            <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short' ,
                                                day: 'numeric' , year: 'numeric' }) %>
                                        </span>
                                    </div>
                                    <h3>
                                        <%= blog.title %>
                                    </h3>
                                    <p class="card-excerpt">
                                        <%- blog.metaDescription ? blog.metaDescription.substring(0, 100) :
                                            blog.content.replace(/<[^>]*>/g, '').substring(0, 100) %>...
                                    </p>
                                    <div class="card-footer">
                                        <div class="card-author">
                                            <div class="author-avatar">AS</div>
                                            <span>Ankit Singh</span>
                                        </div>
                                        <span class="read-more-icon"><i class="fa-solid fa-arrow-right"></i></span>
                                    </div>
                                </div>
                            </a>
                            <% }) %>
                </section>

                <% } else { %>
                    <div class="empty-state">
                        <i class="fa-solid fa-folder-open"></i>
                        <h2>No Articles Found</h2>
                        <p>Check back later for new content!</p>
                    </div>
                    <% } %>

    </main>

    <style>
        /* Global Overrides for modern dark theme */
        body {
            background: #0d0d14 !important;
            color: #f1f1f1;
            font-family: 'Inter', sans-serif;
            padding-top: 90px;
        }

        .aks-blog-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 40px 24px;
        }

        /* Page Header */
        .aks-page-header {
            text-align: center;
            margin-bottom: 60px;
            animation: fadeInDown 0.8s ease-out;
        }

        .aks-page-header h1 {
            font-family: 'Outfit', sans-serif;
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 16px;
            letter-spacing: -0.5px;
        }

        .aks-page-header .highlight {
            background: linear-gradient(135deg, #a5b4fc, #818cf8, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .aks-page-header p {
            font-size: 1.1rem;
            color: #9ca3af;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Animations */
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Hero Section */
        .aks-blog-hero {
            margin-bottom: 50px;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        .hero-card {
            display: flex;
            flex-direction: column;
            border-radius: 24px;
            overflow: hidden;
            text-decoration: none;
            background: rgba(22, 22, 42, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(12px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .hero-card:hover {
            transform: translateY(-8px);
            border-color: rgba(129, 140, 248, 0.3);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 40px rgba(129, 140, 248, 0.1);
        }

        @media (min-width: 992px) {
            .hero-card {
                flex-direction: row;
                height: 480px;
            }
        }

        .hero-image-wrapper {
            position: relative;
            flex: 1.2;
            min-height: 300px;
            overflow: hidden;
        }

        .hero-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s ease;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, rgba(13, 13, 20, 0.9) 0%, rgba(13, 13, 20, 0.2) 100%);
        }

        .hero-card:hover .hero-image {
            transform: scale(1.05);
        }

        .category-badge {
            position: absolute;
            top: 24px;
            left: 24px;
            background: rgba(79, 70, 229, 0.85);
            color: #fff;
            padding: 6px 16px;
            border-radius: 100px;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 2;
        }

        .hero-content {
            flex: 1;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: linear-gradient(135deg, rgba(26, 26, 46, 0.8), rgba(22, 22, 42, 0.9));
        }

        .meta-data {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            font-size: 0.85rem;
            color: #9ca3af;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .meta-data span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .meta-data i {
            color: #818cf8;
        }

        .hero-content h2 {
            font-family: 'Outfit', sans-serif;
            font-size: 2.2rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 16px;
            line-height: 1.25;
            transition: color 0.3s ease;
        }

        .hero-card:hover .hero-content h2 {
            color: #a5b4fc;
        }

        .hero-excerpt {
            font-size: 1.05rem;
            color: #d1d5db;
            line-height: 1.7;
            margin-bottom: 32px;
            flex-grow: 1;
        }

        .btn-read-more {
            align-self: flex-start;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(79, 70, 229, 0.15);
            color: #a5b4fc;
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(129, 140, 248, 0.2);
        }

        .btn-read-more i {
            transition: transform 0.3s ease;
        }

        .hero-card:hover .btn-read-more {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: #fff;
            border-color: transparent;
        }

        .hero-card:hover .btn-read-more i {
            transform: translateX(4px);
        }

        /* Grid Section */
        .aks-blog-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 30px;
            animation: fadeInUp 0.8s ease-out 0.4s both;
        }

        .blog-card {
            display: flex;
            flex-direction: column;
            background: rgba(22, 22, 42, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            overflow: hidden;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            backdrop-filter: blur(10px);
            height: 100%;
        }

        .blog-card:hover {
            transform: translateY(-6px);
            border-color: rgba(129, 140, 248, 0.25);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3), 0 0 20px rgba(79, 70, 229, 0.1);
        }

        .card-image-wrapper {
            position: relative;
            height: 220px;
            overflow: hidden;
        }

        .card-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .blog-card:hover .card-image-wrapper img {
            transform: scale(1.08);
        }

        .card-badge {
            position: absolute;
            bottom: 16px;
            right: 16px;
            background: rgba(13, 13, 20, 0.8);
            color: #a5b4fc;
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .card-content {
            padding: 24px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-meta {
            display: flex;
            gap: 16px;
            font-size: 0.8rem;
            color: #9ca3af;
            margin-bottom: 12px;
        }

        .card-meta span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .card-content h3 {
            font-family: 'Outfit', sans-serif;
            font-size: 1.35rem;
            font-weight: 700;
            color: #f1f1f1;
            margin-bottom: 12px;
            line-height: 1.3;
            transition: color 0.3s ease;
        }

        .blog-card:hover .card-content h3 {
            color: #a5b4fc;
        }

        .card-excerpt {
            font-size: 0.95rem;
            color: #9ca3af;
            line-height: 1.6;
            margin-bottom: 24px;
            flex-grow: 1;
        }

        .card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .card-author {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .author-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .card-author span {
            font-size: 0.85rem;
            font-weight: 600;
            color: #d1d5db;
        }

        .read-more-icon {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.05);
            color: #a5b4fc;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .blog-card:hover .read-more-icon {
            background: rgba(79, 70, 229, 0.2);
            transform: translateX(4px);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            background: rgba(22, 22, 42, 0.3);
            border: 1px dashed rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            color: #9ca3af;
        }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 20px;
            color: #4b5563;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .aks-page-header h1 {
                font-size: 2.2rem;
            }

            .hero-content {
                padding: 30px 20px;
            }

            .hero-content h2 {
                font-size: 1.8rem;
            }

            .aks-blog-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <%- include('partials/footer') %>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Blogs – AKS Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        :root {
            --sidebar-w: 240px;
            --bg: #0d0d14;
            --sidebar: #0f0f1a;
            --surface: #16162a;
            --border: rgba(255, 255, 255, 0.07);
            --primary: #4f46e5;
            --accent: #7c3aed;
            --text: #f1f1f1;
            --muted: #9ca3af;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            margin: 0;
        }

        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px 0;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 0 20px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-brand .icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #fff;
        }

        .sidebar-brand span {
            font-family: 'Outfit', sans-serif;
            font-size: 16px;
            font-weight: 700;
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 0 8px;
            margin: 16px 0 6px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all .15s;
        }

        .nav-item a:hover,
        .nav-item a.active {
            background: rgba(79, 70, 229, .15);
            color: #a5b4fc;
        }

        .nav-item a i {
            width: 18px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid var(--border);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: #fca5a5;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: background .15s;
        }

        .logout-btn:hover {
            background: rgba(239, 68, 68, .1);
        }

        .main-content {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            background: rgba(13, 13, 20, .9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            padding: 16px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar h2 {
            font-size: 18px;
            font-weight: 600;
            font-family: 'Outfit', sans-serif;
            margin: 0;
        }

        .page-body {
            padding: 28px;
            flex: 1;
        }

        .card-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
        }

        .card-header-bar {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
        }

        .card-header-bar h3 {
            font-size: 15px;
            font-weight: 600;
            margin: 0;
        }

        .stats-pills {
            display: flex;
            gap: 10px;
            font-size: 12px;
            color: var(--muted);
        }

        .pill {
            background: rgba(255, 255, 255, .06);
            padding: 4px 12px;
            border-radius: 100px;
        }

        .pill span {
            color: var(--text);
            font-weight: 600;
        }

        .btn-new {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: #fff;
            border: none;
            padding: 9px 18px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .search-bar {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .search-bar input,
        .search-bar select {
            background: rgba(255, 255, 255, .05);
            border: 1px solid var(--border);
            color: var(--text);
            border-radius: 8px;
            padding: 7px 12px;
            font-size: 13px;
            outline: none;
            transition: border-color .2s;
        }

        .search-bar input:focus,
        .search-bar select:focus {
            border-color: var(--primary);
        }

        .search-bar select option {
            background: #1a1a2e;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            background: rgba(255, 255, 255, .03);
        }

        th {
            padding: 12px 14px;
            font-size: 11px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        td {
            padding: 13px 14px;
            font-size: 13px;
            border-bottom: 1px solid rgba(255, 255, 255, .04);
            vertical-align: middle;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: rgba(255, 255, 255, .02);
        }

        .badge {
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-pub {
            background: rgba(16, 185, 129, .15);
            color: #34d399;
        }

        .badge-draft {
            background: rgba(245, 158, 11, .15);
            color: #fbbf24;
        }

        .action-btn {
            padding: 5px 10px;
            border-radius: 7px;
            font-size: 12px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: opacity .15s;
        }

        .action-btn:hover {
            opacity: .8;
        }

        .btn-edit {
            background: rgba(79, 70, 229, .15);
            color: #a5b4fc;
        }

        .btn-view {
            background: rgba(16, 185, 129, .12);
            color: #34d399;
        }

        .btn-toggle-pub {
            background: rgba(16, 185, 129, .15);
            color: #34d399;
        }

        .btn-toggle-draft {
            background: rgba(245, 158, 11, .15);
            color: #fbbf24;
        }

        .btn-delete {
            background: rgba(239, 68, 68, .12);
            color: #fca5a5;
        }

        .empty-row td {
            text-align: center;
            padding: 40px;
            color: var(--muted);
        }

        .top-controls {
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
        }
    </style>
</head>

<body>
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="icon"><i class="fa-solid fa-shield-halved"></i></div>
            <span>AKS Admin</span>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-label">Management</div>
            <div class="nav-item"><a href="/dhanrubi/dashboard"><i class="fa-solid fa-gauge"></i> Dashboard</a></div>
            <div class="nav-item"><a href="/dhanrubi/blogs" class="active"><i class="fa-solid fa-newspaper"></i> All
                    Posts</a></div>
            <div class="nav-item"><a href="/dhanrubi/add_blog"><i class="fa-solid fa-circle-plus"></i> New Post</a>
            </div>
            <div class="nav-item"><a href="/dhanrubi/contacts"><i class="fa-solid fa-envelope"></i> Contacts <% if
                        (locals.unreadContactsCount> 0) { %><span
                            style="background:#ef4444;color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:10px;margin-left:auto;">
                            <%= unreadContactsCount %>
                        </span>
                        <% } %></a></div>
            <div class="nav-label">Account</div>
            <div class="nav-item"><a href="/dhanrubi/change-password"><i class="fa-solid fa-key"></i> Change
                    Password</a></div>
            <div class="nav-label">Website</div>
            <div class="nav-item"><a href="/" target="_blank"><i class="fa-solid fa-globe"></i> View Site</a></div>
            <div class="nav-item"><a href="/blog" target="_blank"><i class="fa-solid fa-rss"></i> View Blog</a></div>
        </nav>
        <div class="sidebar-footer">
            <a href="/dhanrubi/logout" class="logout-btn"><i class="fa-solid fa-right-from-bracket"></i> Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <h2>All Blog Posts</h2>
            <a href="/dhanrubi/add_blog" class="btn-new"><i class="fa-solid fa-plus"></i> New Post</a>
        </div>
        <div class="page-body">
            <div class="card-box">
                <div class="card-header-bar">
                    <div class="stats-pills">
                        <div class="pill">All: <span id="countAll">–</span></div>
                        <div class="pill">Published: <span id="countPublished">–</span></div>
                        <div class="pill">Drafts: <span id="countDrafts">–</span></div>
                    </div>
                </div>
                <div class="top-controls">
                    <div class="search-bar">
                        <input type="text" id="searchInput" placeholder="🔍 Search by title…">
                        <select id="statusFilter">
                            <option value="">All Statuses</option>
                            <option value="Published">Published</option>
                            <option value="Draft">Draft</option>
                        </select>
                        <select id="catFilter">
                            <option value="">All Categories</option>
                        </select>
                    </div>
                </div>
                <div style="overflow-x:auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="blogTableBody">
                            <tr class="empty-row">
                                <td colspan="6"><i class="fa-solid fa-spinner fa-spin"></i> Loading…</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        let allBlogs = [];
        let searchTimeout;

        async function loadBlogs() {
            try {
                const res = await fetch('/api/dhanrubi/blogs', { credentials: 'include' });
                const data = await res.json();
                if (!data.success) { showEmpty('Failed to load posts.'); return; }
                allBlogs = data.blogs;
                renderTable(allBlogs);

                // Populate category filter from backend
                const cats = data.categories || [];
                const catSel = document.getElementById('catFilter');
                cats.forEach(c => { const o = document.createElement('option'); o.value = c; o.textContent = c; catSel.appendChild(o); });
            } catch (e) { console.error(e); showEmpty('Error loading posts.'); }
        }

        function handleSearchInput() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(filterTable, 400); // 400ms debounce
        }

        async function filterTable() {
            const q = document.getElementById('searchInput').value;
            const status = document.getElementById('statusFilter').value;
            const cat = document.getElementById('catFilter').value;

            const params = new URLSearchParams();
            if (q) params.append('search', q);
            if (status) params.append('status', status);
            if (cat) params.append('category', cat);

            try {
                document.getElementById('blogTableBody').innerHTML = '<tr class="empty-row"><td colspan="6"><i class="fa-solid fa-spinner fa-spin"></i> Filtering…</td></tr>';
                const res = await fetch('/api/dhanrubi/blogs?' + params.toString(), { credentials: 'include' });
                const data = await res.json();
                if (!data.success) { showEmpty('Failed to load posts.'); return; }
                allBlogs = data.blogs;
                renderTable(allBlogs);
            } catch (e) { console.error(e); showEmpty('Error loading posts.'); }
        }

        function renderTable(blogs) {
            const tbody = document.getElementById('blogTableBody');
            let pub = 0, drft = 0;
            tbody.innerHTML = '';

            if (!blogs.length) { showEmpty('No posts found.'); return; }

            blogs.forEach((b, i) => {
                if (b.status === 'Published') pub++; else drft++;
                const tr = document.createElement('tr');
                tr.dataset.id = b._id;
                tr.innerHTML = `
                    <td style="color:var(--muted);">${i + 1}</td>
                    <td style="max-width:260px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${b.title}</td>
                    <td style="color:var(--muted);">${b.category || '–'}</td>
                    <td><span class="badge ${b.status === 'Published' ? 'badge-pub' : 'badge-draft'}" id="badge-${b._id}">${b.status}</span></td>
                    <td style="color:var(--muted);font-size:12px;">${new Date(b.createdAt).toLocaleDateString('en-IN')}</td>
                    <td style="display:flex;gap:5px;flex-wrap:wrap;">
                        <a href="/dhanrubi/add_blog?id=${b._id}" class="action-btn btn-edit"><i class="fa-solid fa-pen"></i> Edit</a>
                       <button data-id="${b._id}" class="action-btn ${b.status === 'Published' ? 'btn-toggle-draft' : 'btn-toggle-pub'} toggle-btn" id="toggle-${b._id}"><i class="fa-solid fa-toggle-on"></i> ${b.status === 'Published' ? 'Draft' : 'Publish'}</button>
                        <a href="/blog/${b.slug}" target="_blank" class="action-btn btn-view"><i class="fa-solid fa-eye"></i></a>
                         <button data-id="${b._id}" class="action-btn btn-delete delete-btn"><i class="fa-solid fa-trash"></i></button>
                    </td>`;
                tbody.appendChild(tr);
            });

            document.getElementById('countAll').textContent = allBlogs.length;
            document.getElementById('countPublished').textContent = allBlogs.filter(b => b.status === 'Published').length;
            document.getElementById('countDrafts').textContent = allBlogs.filter(b => b.status === 'Draft').length;
        }

        function showEmpty(msg) {
            document.getElementById('blogTableBody').innerHTML = `<tr class="empty-row"><td colspan="6">${msg}</td></tr>`;
        }

        async function toggleStatus(id) {
            try {
                const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                const res = await fetch(`/admin/blog/toggle-status/${id}`, {
                    method: 'POST',
                    headers: { 'csrf-token': csrfToken, 'Content-Type': 'application/json' },
                    credentials: 'include'
                });
                const data = await res.json();
                if (data.success) {
                    const blog = allBlogs.find(b => b._id === id);
                    const newStatus = data.newStatus.charAt(0).toUpperCase() + data.newStatus.slice(1);
                    if (blog) { blog.status = newStatus; }
                    const badge = document.getElementById(`badge-${id}`);
                    const btn = document.getElementById(`toggle-${id}`);
                    if (badge) { badge.textContent = newStatus; badge.className = `badge ${newStatus === 'Published' ? 'badge-pub' : 'badge-draft'}`; }
                    if (btn) { btn.innerHTML = `<i class="fa-solid fa-toggle-on"></i> ${newStatus === 'Published' ? 'Draft' : 'Publish'}`; btn.className = `action-btn ${newStatus === 'Published' ? 'btn-toggle-draft' : 'btn-toggle-pub'}`; }
                    document.getElementById('countPublished').textContent = allBlogs.filter(b => b.status === 'Published').length;
                    document.getElementById('countDrafts').textContent = allBlogs.filter(b => b.status === 'Draft').length;
                } else { alert('Error: ' + data.message); }
            } catch (e) { console.error(e); alert('Network error'); }
        }

        async function deleteBlog(id) {
            if (!confirm('⚠️ Delete this blog permanently? This cannot be undone.')) return;
            try {
                const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                const res = await fetch(`/admin/blog/${id}`, {
                    method: 'DELETE',
                    headers: { 'csrf-token': csrfToken, 'Content-Type': 'application/json' },
                    credentials: 'include'
                });
                const data = await res.json();
                if (data.success) {
                    allBlogs = allBlogs.filter(b => b._id !== id);
                    renderTable(allBlogs);
                } else { alert('Error: ' + data.message); }
            } catch (e) { console.error(e); alert('Network error'); }
        }

        // document.addEventListener('DOMContentLoaded', loadBlogs);


        document.addEventListener('click', function (e) {
            if (e.target.closest('.delete-btn')) {
                const btn = e.target.closest('.delete-btn');
                const id = btn.getAttribute('data-id');
                deleteBlog(id);
            }
        });


        document.addEventListener('click', function (e) {
            if (e.target.closest('.toggle-btn')) {
                const btn = e.target.closest('.toggle-btn');
                const id = btn.getAttribute('data-id');
                toggleStatus(id);
            }
        });




        document.addEventListener('DOMContentLoaded', () => {
            loadBlogs();

            document.getElementById('searchInput').addEventListener('input', handleSearchInput);
            document.getElementById('statusFilter').addEventListener('change', filterTable);
            document.getElementById('catFilter').addEventListener('change', filterTable);
        });

    </script>

</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title id="pageTitle">Add New Post – AKS Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700&display=swap"
        rel="stylesheet">
    
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        :root {
            --sidebar-w: 240px;
            --bg: #0d0d14;
            --sidebar: #0f0f1a;
            --surface: #16162a;
            --surface2: #1a1a2e;
            --border: rgba(255, 255, 255, 0.07);
            --primary: #4f46e5;
            --accent: #7c3aed;
            --text: #f1f1f1;
            --muted: #9ca3af;
            --input-bg: #0f0f1a;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            margin: 0;
        }

        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px 0;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 0 20px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-brand .icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #fff;
        }

        .sidebar-brand span {
            font-family: 'Outfit', sans-serif;
            font-size: 16px;
            font-weight: 700;
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 0 8px;
            margin: 16px 0 6px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all .15s;
        }

        .nav-item a:hover,
        .nav-item a.active {
            background: rgba(79, 70, 229, .15);
            color: #a5b4fc;
        }

        .nav-item a i {
            width: 18px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid var(--border);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: #fca5a5;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: background .15s;
        }

        .logout-btn:hover {
            background: rgba(239, 68, 68, .1);
        }

        .main-content {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            background: rgba(13, 13, 20, .9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            padding: 16px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar h2 {
            font-size: 18px;
            font-weight: 600;
            font-family: 'Outfit', sans-serif;
            margin: 0;
        }

        .page-body {
            padding: 24px 28px;
            flex: 1;
        }

        .form-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 20px;
        }

        .form-card h3 {
            font-size: 13px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-card h3 i {
            color: #818cf8;
        }

        label {
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 6px;
            display: block;
        }

        .form-control,
        .form-select {
            background: var(--input-bg) !important;
            border: 1px solid var(--border) !important;
            color: var(--text) !important;
            border-radius: 10px !important;
            padding: 11px 14px !important;
            font-size: 14px !important;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .18) !important;
        }

        .form-control::placeholder {
            color: #4b5563;
        }

        .form-select option {
            background: #1a1a2e;
            color: var(--text);
        }

        #errorBox {
            display: none;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 14px;
            margin-bottom: 16px;
        }

        .btn-submit {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            color: #fff;
            border: none;
            padding: 13px 32px;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: opacity .2s;
        }

        .btn-submit:hover {
            opacity: .88;
        }

        .btn-secondary-sm {
            background: rgba(255, 255, 255, .07);
            border: 1px solid var(--border);
            color: var(--muted);
            padding: 7px 14px;
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
        }

        .btn-danger-sm {
            background: rgba(239, 68, 68, .12);
            border: 1px solid rgba(239, 68, 68, .2);
            color: #fca5a5;
            padding: 5px 10px;
            border-radius: 7px;
            font-size: 12px;
            cursor: pointer;
        }

        .schema-card {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 14px;
        }

        .schema-card-header {
            padding: 10px 16px;
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .schema-card-body {
            padding: 16px;
        }

        .form-check-input {
            background-color: var(--input-bg);
            border-color: var(--border);
        }

        .form-check-input:checked {
            background-color: var(--primary);
            border-color: var(--primary);
        }

        .form-check-label {
            color: var(--muted);
            font-size: 13px;
        }

        /* Quill overrides for dark mode */
        .ql-toolbar.ql-snow {
            background: #111122;
            border: 1px solid var(--border) !important;
            border-radius: 10px 10px 0 0;
            padding: 10px;
        }

        .ql-container.ql-snow {
            background: #0d0d18;
            border: 1px solid var(--border) !important;
            border-top: none !important;
            border-radius: 0 0 10px 10px;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: var(--text);
            min-height: 300px;
        }

        .ql-toolbar .ql-stroke {
            stroke: #9ca3af;
        }

        .ql-toolbar .ql-fill {
            fill: #9ca3af;
        }

        .ql-toolbar .ql-picker-label {
            color: #9ca3af;
        }

        .ql-toolbar button:hover .ql-stroke,
        .ql-toolbar .ql-active .ql-stroke {
            stroke: #818cf8;
        }

        .ql-toolbar button:hover .ql-fill,
        .ql-toolbar .ql-active .ql-fill {
            fill: #818cf8;
        }

        .ql-toolbar .ql-picker-options {
            background: #1a1a2e;
            border: 1px solid var(--border);
            color: var(--text);
        }

        .ql-editor.ql-blank::before {
            color: #4b5563;
        }
    </style>
</head>

<body>
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="icon"><i class="fa-solid fa-shield-halved"></i></div>
            <span>AKS Admin</span>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-label">Management</div>
            <div class="nav-item"><a href="/dhanrubi/dashboard"><i class="fa-solid fa-gauge"></i> Dashboard</a></div>
            <div class="nav-item"><a href="/dhanrubi/blogs"><i class="fa-solid fa-newspaper"></i> All Posts</a></div>
            <div class="nav-item"><a href="/dhanrubi/add_blog" class="active"><i class="fa-solid fa-circle-plus"></i>
                    New Post</a></div>
            <div class="nav-item"><a href="/dhanrubi/contacts"><i class="fa-solid fa-envelope"></i> Contacts <% if
                        (locals.unreadContactsCount> 0) { %><span
                            style="background:#ef4444;color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:10px;margin-left:auto;">
                            <%= unreadContactsCount %>
                        </span>
                        <% } %></a></div>
            <div class="nav-label">Account</div>
            <div class="nav-item"><a href="/dhanrubi/change-password"><i class="fa-solid fa-key"></i> Change
                    Password</a></div>
            <div class="nav-label">Website</div>
            <div class="nav-item"><a href="/" target="_blank"><i class="fa-solid fa-globe"></i> View Site</a></div>
            <div class="nav-item"><a href="/blog" target="_blank"><i class="fa-solid fa-rss"></i> View Blog</a></div>
        </nav>
        <div class="sidebar-footer">
            <a href="/dhanrubi/logout" class="logout-btn"><i class="fa-solid fa-right-from-bracket"></i> Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <h2 id="pageHeaderTitle">Add New Post</h2>
            <a href="/dhanrubi/blogs" style="color:var(--muted);font-size:13px;text-decoration:none;"><i
                    class="fa-solid fa-arrow-left"></i> All Posts</a>
        </div>
        <div class="page-body">
            <div id="errorBox"></div>
            <form id="blogForm">
                <input type="hidden" id="blogId" value="">
                <!-- Basic Info -->
                <div class="form-card">
                    <h3><i class="fa-solid fa-pencil"></i> Post Details</h3>
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="title">Blog Title <span style="color:#ef4444;">*</span></label>
                            <input type="text" class="form-control" id="title" placeholder="Enter blog post title"
                                required>
                        </div>
                        <div class="col-12">
                            <label for="slug">URL Slug <span style="color:#ef4444;">*</span></label>
                            <input type="text" class="form-control" id="slug" placeholder="auto-generated-from-title"
                                required>
                        </div>
                        <div class="col-md-6">
                            <label for="category">Category</label>
                            <select class="form-select" id="category">
                                <option value="">Select Category</option>
                                <option value="Education">Education</option>
                                <option value="Artificial Intelligence">Artificial Intelligence</option>
                                <option value="Machine Learning">Machine Learning</option>
                                <option value="ChatGPT & AI Tools">ChatGPT &amp; AI Tools</option>
                                <option value="SEO">SEO</option>
                                <option value="Digital Marketing">Digital Marketing</option>
                                <option value="Blogging">Blogging</option>
                                <option value="Content Marketing">Content Marketing</option>
                                <option value="Full Stack Development">Full Stack Development</option>
                                <option value="Web Development">Web Development</option>
                                <option value="Frontend Development">Frontend Development</option>
                                <option value="Backend Development">Backend Development</option>
                                <option value="MERN Stack">MERN Stack</option>
                                <option value="React JS">React JS</option>
                                <option value="Node JS">Node JS</option>
                                <option value="JavaScript">JavaScript</option>
                                <option value="Programming">Programming</option>
                                <option value="Tech Tutorials">Tech Tutorials</option>
                                <option value="How-To Guides">How-To Guides</option>
                                <option value="DevOps">DevOps</option>
                                <option value="Cloud Computing">Cloud Computing</option>
                                <option value="AWS">AWS</option>
                                <option value="Docker">Docker</option>
                                <option value="Cybersecurity">Cybersecurity</option>
                                <option value="Data Science">Data Science</option>
                                <option value="Database">Database</option>
                                <option value="MongoDB">MongoDB</option>
                                <option value="MySQL">MySQL</option>
                                <option value="Tech News">Tech News</option>
                                <option value="Startup">Startup</option>
                                <option value="Career & Jobs">Career &amp; Jobs</option>
                                <option value="Freelancing">Freelancing</option>
                                <option value="Interview Preparation">Interview Preparation</option>
                                <option value="UI UX Design">UI UX Design</option>
                                <option value="Mobile App Development">Mobile App Development</option>
                                <option value="Blockchain">Blockchain</option>
                                <option value="Open Source">Open Source</option>
                                <option value="Git & GitHub">Git &amp; GitHub</option>
                                <option value="Law">Law</option>
                                <option value="News">News</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="tags">Tags (comma separated)</label>
                            <input type="text" class="form-control" id="tags"
                                placeholder="e.g. nodejs, express, tutorial">
                        </div>
                        <div class="col-md-6">
                            <label for="status">Status</label>
                            <select class="form-select" id="status">
                                <option value="Published">Published</option>
                                <option value="Draft">Draft</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="image" id="imageLabel">Featured Image</label>
                            <input type="file" class="form-control" id="image" accept="image/*" required>
                            <div id="currentImageWrapper" style="display:none;margin-top:8px;">
                                <small style="color:var(--muted);">Current: <span id="currentImageName"></span></small>
                            </div>
                        </div>
                       <div class="col-12">
                        <label for="content">Content (HTML/CSS Supported) <span style="color:#ef4444;">*</span></label>
                        <textarea class="form-control" id="content" rows="15" placeholder="Write your blog content here (HTML supported)…"></textarea>
                        </div>
                    </div>
                </div>
                <!-- SEO -->
                <div class="form-card">
                    <h3><i class="fa-solid fa-magnifying-glass"></i> SEO & Metadata</h3>
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="metaTitle">Meta Title (55–60 chars)</label>
                            <input type="text" class="form-control" id="metaTitle" placeholder="Enter meta title">
                        </div>
                        <div class="col-12">
                            <label for="metaKeywords">Meta Keywords</label>
                            <input type="text" class="form-control" id="metaKeywords"
                                placeholder="e.g. nodejs, express, web dev">
                        </div>
                        <div class="col-12">
                            <label for="metaDescription">Meta Description (&lt;160 chars)</label>
                            <textarea class="form-control" id="metaDescription" rows="3"
                                placeholder="Short SEO description"></textarea>
                        </div>
                    </div>
                </div>
                <!-- Schema -->
                <div class="form-card">
                    <h3><i class="fa-solid fa-code"></i> Schema Markup</h3>
                    <div class="schema-card">
                        <div class="schema-card-header"><i class="fa-solid fa-question-circle"></i> FAQ Schema</div>
                        <div class="schema-card-body" id="faqContainer">
                            <button type="button" class="btn-secondary-sm" id="addFaqBtn"><i
                                    class="fa-solid fa-plus"></i> Add FAQ</button>
                        </div>
                    </div>
                    <div class="schema-card">
                        <div class="schema-card-header"><i class="fa-solid fa-sitemap"></i> Breadcrumb Schema</div>
                        <div class="schema-card-body">
                            <p style="font-size:13px;color:var(--muted);margin-bottom:10px;">Auto-generated: Home › Blog
                                › Post Title</p>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="enableBreadcrumb" checked>
                                <label class="form-check-label" for="enableBreadcrumb">Enable Breadcrumb Schema</label>
                            </div>
                        </div>
                    </div>
                    <div class="schema-card">
                        <div class="schema-card-header"><i class="fa-solid fa-star"></i> Rating Schema</div>
                        <div class="schema-card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="ratingValue">Rating (e.g. 4.5)</label>
                                    <input type="number" step="0.1" min="0" max="5" class="form-control"
                                        id="ratingValue" placeholder="4.5">
                                </div>
                                <div class="col-md-6">
                                    <label for="ratingCount">Reviews (e.g. 120)</label>
                                    <input type="number" class="form-control" id="ratingCount" placeholder="120">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div style="text-align:right;padding-bottom:40px;">
                    <button type="submit" class="btn-submit" id="submitBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Publish Post
                    </button>
                </div>
            </form>
        </div>
    </div>

    
    
    <script>
        // ── Quill initialization ─────────────────────────────────────────────────
   

        // ── Edit Mode ────────────────────────────────────────────────────────────
        const urlParams = new URLSearchParams(window.location.search);
        const editId = urlParams.get('id');

        if (editId) {
            document.getElementById('blogId').value = editId;
            document.getElementById('pageTitle').textContent = 'Edit Post – AKS Admin';
            document.getElementById('pageHeaderTitle').textContent = 'Edit Blog Post';
            document.getElementById('submitBtn').innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Update Post';
            document.getElementById('image').required = false;
            document.getElementById('imageLabel').textContent = 'Featured Image (leave blank to keep existing)';
            fetchBlogData(editId);
        }

        async function fetchBlogData(id) {
            try {
                const res = await fetch(`/api/dhanrubi/blog/id/${id}`);
                const data = await res.json();
                if (!data.success) { Swal.fire({ icon: 'error', title: 'Error', text: 'Blog not found', background: '#1a1a2e', color: '#f1f1f1' }); return; }
                const b = data.blog;
                document.getElementById('title').value = b.title;
                document.getElementById('slug').value = b.slug;
                document.getElementById('category').value = b.category;
                document.getElementById('tags').value = (b.tags || []).join(', ');
                document.getElementById('status').value = b.status === 'Active' ? 'Published' : b.status;
                document.getElementById('metaTitle').value = b.metaTitle || '';
                document.getElementById('metaKeywords').value = b.metaKeywords || '';
                document.getElementById('metaDescription').value = b.metaDescription || '';
                document.getElementById('ratingValue').value = b.ratingValue || '';
                document.getElementById('ratingCount').value = b.ratingCount || '';
                if (b.image) { document.getElementById('currentImageWrapper').style.display = 'block'; document.getElementById('currentImageName').textContent = b.image; }
                // Set Quill content
                document.getElementById("content").value = b.content || '';
                const faqData = JSON.parse(b.faqSchema || '[]');
                faqData.forEach(f => addFaq(f.question, f.answer));
                const bcData = JSON.parse(b.breadcrumbSchema || '[]');
                document.getElementById('enableBreadcrumb').checked = bcData.length > 0;
            } catch (e) { console.error(e); }
        }

        function generateSlug() {
            const editId = document.getElementById('blogId').value;
            if (editId) return;

            const t = document.getElementById('title').value;

            const s = t.toLowerCase()
                .trim()
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-');

            document.getElementById('slug').value = s;
        }

        function addFaq(q = '', a = '') {
            const container = document.getElementById('faqContainer');
            const div = document.createElement('div');
            div.className = 'faq-item row g-2 mb-2';
            div.innerHTML = `
                <div class="col-md-5"><input type="text" class="form-control faq-qs" placeholder="Question" value="${q.replace(/"/g, '&quot;')}"></div>
                <div class="col-md-6"><input type="text" class="form-control faq-ans" placeholder="Answer" value="${a.replace(/"/g, '&quot;')}"></div>
                <div class="col-md-1 d-flex align-items-center"><button type="button" class="btn-danger-sm remove-faq"><i class="fa-solid fa-xmark"></i></button></div>`;
            container.insertBefore(div, document.getElementById('addFaqBtn'));
        }

        // FAQ Event Listeners
        document.getElementById('addFaqBtn').addEventListener('click', () => addFaq());
        document.getElementById('faqContainer').addEventListener('click', (e) => {
            if (e.target.closest('.remove-faq')) {
                e.target.closest('.faq-item').remove();
            }
        });

        function getFaqData() {
            const faqs = [];
            document.querySelectorAll('.faq-item').forEach(item => {
                const q = item.querySelector('.faq-qs').value.trim();
                const a = item.querySelector('.faq-ans').value.trim();
                if (q && a) faqs.push({ question: q, answer: a });
            });
            return JSON.stringify(faqs);
        }

        function showError(msg, type = 'error') {
            const box = document.getElementById('errorBox');
            box.style.display = 'block';
            box.textContent = msg;
            box.style.background = type === 'error' ? 'rgba(239,68,68,0.12)' : 'rgba(16,185,129,0.12)';
            box.style.color = type === 'error' ? '#fca5a5' : '#34d399';
            box.style.border = type === 'error' ? '1px solid rgba(239,68,68,0.3)' : '1px solid rgba(16,185,129,0.3)';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

      document.getElementById('blogForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    const htmlContent = document.getElementById("content").value;

    if (!htmlContent.trim()) {
        showError('Content is required. Please write something.');
        return;
    }

    document.getElementById('content').value = htmlContent;

    const title = document.getElementById('title').value.trim();
    const slug = document.getElementById('slug').value.trim();
    const enableBreadcrumb = document.getElementById('enableBreadcrumb').checked;
            const breadcrumbData = enableBreadcrumb
                ? JSON.stringify([{ name: 'Home', url: 'https://codewithaks.in/' }, { name: 'Blog', url: 'https://codewithaks.in/blog/' }, { name: title, url: `https://codewithaks.in/blog/${slug}` }])
                : '[]';

            const formData = new FormData();
            formData.append('title', title);
            formData.append('slug', slug);
            formData.append('category', document.getElementById('category').value);
            formData.append('tags', document.getElementById('tags').value);
            formData.append('status', document.getElementById('status').value);
            formData.append('content', htmlContent);
            formData.append('metaTitle', document.getElementById('metaTitle').value);
            formData.append('metaKeywords', document.getElementById('metaKeywords').value);
            formData.append('metaDescription', document.getElementById('metaDescription').value);
            formData.append('faqSchema', getFaqData());
            formData.append('breadcrumbSchema', breadcrumbData);
            formData.append('ratingValue', document.getElementById('ratingValue').value || 0);
            formData.append('ratingCount', document.getElementById('ratingCount').value || 0);
            const imageFile = document.getElementById('image').files[0];
            if (imageFile) formData.append('image', imageFile);

            const id = document.getElementById('blogId').value;
            const url = id ? `/api/dhanrubi/blog/update/${id}` : '/api/dhanrubi/blog/add';
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving…';

            try {
                const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    headers: { 'csrf-token': csrfToken }
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: id ? 'Updated!' : 'Published!', text: data.message, background: '#0f0f1a', color: '#f1f1f1', timer: 2000, showConfirmButton: false })
                        .then(() => { window.location.href = '/dhanrubi/blogs'; });
                } else {
                    showError(data.message || 'Submission failed');
                    btn.disabled = false;
                    btn.innerHTML = `<i class="fa-solid fa-floppy-disk"></i> ${id ? 'Update Post' : 'Publish Post'}`;
                }
            } catch (err) {
                showError('Network error. Please try again.');
                btn.disabled = false;
                btn.innerHTML = `<i class="fa-solid fa-floppy-disk"></i> ${id ? 'Update Post' : 'Publish Post'}`;
            }
        });




        document.getElementById('title').addEventListener('input', generateSlug);
    </script>
</body>

</html>

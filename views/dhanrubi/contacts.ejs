<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Messages – AKS Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        :root {
            --sidebar-w: 240px;
            --bg: #0d0d14;
            --sidebar: #0f0f1a;
            --surface: #16162a;
            --surface2: #1a1a2e;
            --border: rgba(255, 255, 255, 0.07);
            --primary: #4f46e5;
            --accent: #7c3aed;
            --text: #f1f1f1;
            --muted: #9ca3af;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            margin: 0;
        }

        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px 0;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 0 20px 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-brand .icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #fff;
        }

        .sidebar-brand span {
            font-family: 'Outfit', sans-serif;
            font-size: 16px;
            font-weight: 700;
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 0 8px;
            margin: 16px 0 6px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all .15s;
        }

        .nav-item a:hover,
        .nav-item a.active {
            background: rgba(79, 70, 229, .15);
            color: #a5b4fc;
        }

        .nav-item a i {
            width: 18px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid var(--border);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: #fca5a5;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: background .15s;
        }

        .logout-btn:hover {
            background: rgba(239, 68, 68, .1);
        }

        .main-content {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            background: rgba(13, 13, 20, .9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            padding: 16px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar h2 {
            font-size: 18px;
            font-weight: 600;
            font-family: 'Outfit', sans-serif;
            margin: 0;
        }

        .unread-badge {
            background: rgba(239, 68, 68, .15);
            border: 1px solid rgba(239, 68, 68, .3);
            color: #fca5a5;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 100px;
        }

        .contacts-layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 0;
            flex: 1;
            height: calc(100vh - 65px);
        }

        /* Left panel */
        .contacts-list {
            border-right: 1px solid var(--border);
            overflow-y: auto;
            background: var(--sidebar);
        }

        .contacts-list-header {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
        }

        .contact-item {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, .04);
            cursor: pointer;
            transition: background .15s;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .contact-item:hover {
            background: rgba(79, 70, 229, .08);
        }

        .contact-item.active {
            background: rgba(79, 70, 229, .15);
            border-left: 3px solid var(--primary);
        }

        .contact-item.unread .contact-name {
            font-weight: 700;
            color: var(--text);
        }

        .contact-avatar {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .contact-name {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .contact-preview {
            font-size: 12px;
            color: var(--muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-top: 2px;
        }

        .contact-meta {
            margin-left: auto;
            text-align: right;
            flex-shrink: 0;
        }

        .contact-date {
            font-size: 11px;
            color: var(--muted);
        }

        .unread-dot {
            width: 7px;
            height: 7px;
            background: #ef4444;
            border-radius: 50%;
            margin: 4px 0 0 auto;
        }

        /* Right panel */
        .contact-detail {
            padding: 28px;
            overflow-y: auto;
            background: var(--bg);
        }

        .detail-empty {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--muted);
            gap: 12px;
        }

        .detail-empty i {
            font-size: 48px;
            opacity: .3;
        }

        .detail-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
        }

        .detail-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .detail-name {
            font-size: 20px;
            font-weight: 700;
            margin: 0;
        }

        .detail-email {
            font-size: 13px;
            color: var(--muted);
            margin-top: 3px;
        }

        .detail-actions {
            display: flex;
            gap: 8px;
        }

        .action-btn {
            padding: 7px 14px;
            border-radius: 8px;
            font-size: 13px;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: opacity .15s;
        }

        .action-btn:hover {
            opacity: .8;
        }

        .btn-read {
            background: rgba(16, 185, 129, .12);
            color: #34d399;
        }

        .btn-delete {
            background: rgba(239, 68, 68, .12);
            color: #fca5a5;
        }

        .detail-meta {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .meta-chip {
            background: var(--surface2);
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 12px;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .meta-chip i {
            color: #818cf8;
        }

        .detail-message {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            font-size: 14px;
            line-height: 1.7;
            color: #d1d5db;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .badge-read {
            background: rgba(16, 185, 129, .12);
            color: #34d399;
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-unread {
            background: rgba(239, 68, 68, .12);
            color: #fca5a5;
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 600;
        }

        .no-contacts {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 60px;
            color: var(--muted);
            gap: 10px;
        }

        .no-contacts i {
            font-size: 40px;
            opacity: .3;
        }
    </style>
</head>

<body>
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="icon"><i class="fa-solid fa-shield-halved"></i></div>
            <span>AKS Admin</span>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-label">Management</div>
            <div class="nav-item"><a href="/dhanrubi/dashboard"><i class="fa-solid fa-gauge"></i> Dashboard</a></div>
            <div class="nav-item"><a href="/dhanrubi/blogs"><i class="fa-solid fa-newspaper"></i> All Posts</a></div>
            <div class="nav-item"><a href="/dhanrubi/add_blog"><i class="fa-solid fa-circle-plus"></i> New Post</a>
            </div>
            <div class="nav-item"><a href="/dhanrubi/contacts" class="active"><i class="fa-solid fa-envelope"></i>
                    Contacts <% if (locals.unreadContactsCount> 0) { %><span id="sidebar-unread-badge"
                            style="background:#ef4444;color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:10px;margin-left:auto;">
                            <%= unreadContactsCount %>
                        </span>
                        <% } %></a></div>
            <div class="nav-label">Account</div>
            <div class="nav-item"><a href="/dhanrubi/change-password"><i class="fa-solid fa-key"></i> Change
                    Password</a></div>
            <div class="nav-label">Website</div>
            <div class="nav-item"><a href="/" target="_blank"><i class="fa-solid fa-globe"></i> View Site</a></div>
            <div class="nav-item"><a href="/blog" target="_blank"><i class="fa-solid fa-rss"></i> View Blog</a></div>
        </nav>
        <div class="sidebar-footer">
            <a href="/dhanrubi/logout" class="logout-btn"><i class="fa-solid fa-right-from-bracket"></i> Sign Out</a>
        </div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div style="display:flex;align-items:center;gap:12px;">
                <h2>Contact Messages</h2>
                <% const unreadCount=contacts.filter(c=> !c.isRead).length; %>
                    <% if (unreadCount> 0) { %>
                        <span class="unread-badge" id="topbar-unread-badge">
                            <%= unreadCount %> new
                        </span>
                        <% } %>
            </div>
            <span style="font-size:13px;color:var(--muted);">
                <%= contacts.length %> total
            </span>
        </div>

        <div class="contacts-layout">
            <!-- Left: Contact List -->
            <div class="contacts-list">
                <div class="contacts-list-header">Inbox</div>
                <% if (contacts.length===0) { %>
                    <div class="no-contacts">
                        <i class="fa-solid fa-inbox"></i>
                        <span>No messages yet</span>
                    </div>
                    <% } else { %>
                        <% contacts.forEach(function(c) { %>
                            <div class="contact-item contact-click <%= !c.isRead ? 'unread' : '' %>"
                                id="list-item-<%= c._id %>" data-id="<%= c._id %>" data-name="<%= c.name %>"
                                data-email="<%= c.email %>" data-phone="<%= c.phone || '' %>"
                                data-message="<%= c.message %>" data-isread="<%= c.isRead %>"
                                data-date="<%= new Date(c.createdAt).toLocaleString('en-IN') %>">
                                <div class="contact-avatar">
                                    <%= c.name.charAt(0).toUpperCase() %>
                                </div>
                                <div style="flex:1;min-width:0;">
                                    <div class="contact-name">
                                        <%= c.name %>
                                    </div>
                                    <div class="contact-preview">
                                        <%= c.message.substring(0, 50) %>
                                            <%= c.message.length> 50 ? '…' : '' %>
                                    </div>
                                </div>
                                <div class="contact-meta">
                                    <div class="contact-date">
                                        <%= new Date(c.createdAt).toLocaleDateString('en-IN') %>
                                    </div>
                                    <% if (!c.isRead) { %>
                                        <div class="unread-dot"></div>
                                        <% } %>
                                </div>
                            </div>
                            <% }); %>
                                <% } %>
            </div>

            <!-- Right: Detail Panel -->
            <div class="contact-detail" id="detailPanel">
                <div class="detail-empty">
                    <i class="fa-solid fa-envelope-open-text"></i>
                    <span>Select a message to view</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        let activeId = null;

        function showContact(el) {
            const id = el.dataset.id;
            const name = el.dataset.name;
            const email = el.dataset.email;
            const phone = el.dataset.phone;
            const message = el.dataset.message;
            const isRead = el.dataset.isread;
            const date = el.dataset.date;

            activeId = id;
            // Highlight in list
            document.querySelectorAll('.contact-item').forEach(e => e.classList.remove('active'));
            el.classList.add('active');

            // Mark as read automatically
            if (isRead === 'false') {
                markRead(id);
                el.classList.remove('unread');
                const dot = el.querySelector('.unread-dot');
                if (dot) dot.remove();
                el.dataset.isread = 'true';

                // Decrement badges
                decrementBadges();
            }

            // textContent safely escapes HTML
            const decodedMessage = document.createElement('div');
            decodedMessage.textContent = message;

            const readBadge = isRead === 'true' || isRead === true
                ? '<span class="badge-read"><i class="fa-solid fa-check"></i> Read</span>'
                : '<span class="badge-unread"><i class="fa-solid fa-circle"></i> Unread</span>';
            const safeName = document.createElement('div');
            safeName.textContent = name;

            const safeEmail = document.createElement('div');
            safeEmail.textContent = email;

            const safePhone = document.createElement('div');
            safePhone.textContent = phone;

            document.getElementById('detailPanel').innerHTML = `
                <div class="detail-card">
                    <div class="detail-header">
                        <div>
                            
                            <h2 class="detail-name">${safeName.innerHTML}</h2>
                            <div class="detail-email">${safeEmail.innerHTML}</div>
                        </div>
                        <div class="detail-actions">
                            <button data-id="${id}" class="action-btn btn-delete delete-contact-btn">
    <i class="fa-solid fa-trash"></i> Delete
</button>
                        </div>
                    </div>
                    <div class="detail-meta">
                        <div class="meta-chip"><i class="fa-solid fa-envelope"></i> ${safeEmail.innerHTML}</div>
                        ${phone ? `<div class="meta-chip"><i class="fa-solid fa-phone"></i> ${safePhone.innerHTML}</div>` : ''}
                        <div class="meta-chip"><i class="fa-solid fa-calendar"></i> ${date}</div>
                        <div>${readBadge}</div>
                    </div>
                    <h4 style="font-size:13px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px;">Message</h4>
                    <div class="detail-message"><p style="line-height:1.6;text-align:justify;white-space:pre-wrap;margin-bottom:5px">${decodedMessage.innerHTML}</p></div>
                </div>`;
        }

        function decrementBadges() {
            const sidebarBadge = document.getElementById('sidebar-unread-badge');
            if (sidebarBadge) {
                let count = parseInt(sidebarBadge.textContent);
                if (count > 1) { sidebarBadge.textContent = count - 1; }
                else { sidebarBadge.remove(); }
            }
            const topbarBadge = document.getElementById('topbar-unread-badge');
            if (topbarBadge) {
                let count = parseInt(topbarBadge.textContent);
                if (count > 1) { topbarBadge.textContent = (count - 1) + ' new'; }
                else { topbarBadge.remove(); }
            }
        }

        async function markRead(id) {
            try {
                const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                await fetch(`/admin/contact/read/${id}`, {
                    method: 'POST',
                    headers: { 'csrf-token': csrfToken, 'Content-Type': 'application/json' },
                    credentials: 'same-origin'
                });
            } catch (e) { console.error(e); }
        }

        async function deleteContact(id) {
            if (!confirm('Delete this contact message permanently?')) return;
            try {
                const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                const res = await fetch(`/admin/contact/${id}`, {
                    method: 'DELETE',
                    headers: { 'csrf-token': csrfToken, 'Content-Type': 'application/json' },
                    credentials: 'same-origin'
                });
                const data = await res.json();
                if (data.success) {
                    const el = document.getElementById(`list-item-${id}`);
                    if (el && el.dataset.isread === 'false') { decrementBadges(); }
                    if (el) el.remove();
                    document.getElementById('detailPanel').innerHTML = '<div class="detail-empty"><i class="fa-solid fa-envelope-open-text"></i><span>Message deleted</span></div>';
                } else { alert('Error: ' + data.message); }
            } catch (e) { alert('Network error'); }
        }



        document.addEventListener('click', function (e) {
            if (e.target.closest('.contact-click')) {
                const el = e.target.closest('.contact-click');
                showContact(el);
            }
        });

        document.addEventListener('click', function (e) {
            if (e.target.closest('.delete-contact-btn')) {
                const btn = e.target.closest('.delete-contact-btn');
                const id = btn.getAttribute('data-id');
                deleteContact(id);
            }
        });
    </script>
</body>

</html>